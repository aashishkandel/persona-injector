{
	"name": "ai-personas",
	"version": "1.0.0",
	"description": "Inject domain-specific AI personas into your repo for GitHub Copilot, Claude Code & more. Workflow-embedded context systems with checklists, anti-patterns, and file-scoped rules.",
	"type": "module",
	"bin": {
		"ai-personas": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js"
		},
		"./cli": "./dist/cli.js"
	},
	"files": [
		"dist",
		"personas",
		"README.md",
		"LICENSE"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"prepublishOnly": "npm run build",
		"prepare": "npm run build",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"format": "biome format --write ."
	},
	"keywords": [
		"ai",
		"persona",
		"copilot",
		"claude",
		"cursor",
		"windsurf",
		"cline",
		"cli",
		"developer-tools",
		"ai-context",
		"code-assistant"
	],
	"author": "Aashish Kandel",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aashishkandel/ai-personas.git"
	},
	"homepage": "https://github.com/aashishkandel/ai-personas#readme",
	"bugs": {
		"url": "https://github.com/aashishkandel/ai-personas/issues"
	},
	"dependencies": {
		"@clack/prompts": "^1.2.0",
		"commander": "^14.0.3",
		"picocolors": "^1.1.1",
		"yocto-spinner": "^1.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/node": "^25.5.0",
		"tsup": "^8.5.1",
		"typescript": "^6.0.2",
		"vitest": "^4.1.2"
	}
}
